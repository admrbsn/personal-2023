---
import { Image } from 'astro:assets'
import dashboard1 from '../assets/img/tribute-v3-audience-dashboard-1.png'
import dashboard2 from '../assets/img/tribute-v3-audience-dashboard-2.png'
import dashboard3 from '../assets/img/tribute-v3-audience-dashboard-3.png'
import dashboard5 from '../assets/img/tribute-v3-audience-dashboard-5.png'

const items = [
  { img: dashboard1, label: 'Audience insights: Demographics tab' },
  { img: dashboard2, label: 'Audience insights: Location tab' },
  { img: dashboard3, label: 'Audience insights: Business & Occupation tab' },
  { img: dashboard5, label: 'Audience insights: access gate' },
] as const
---

<div
  id="audience-insights-thumbs"
  class="audience-insights-thumb-row not-prose my-8 grid grid-cols-2 gap-2 sm:grid-cols-4 sm:gap-3"
>
  {
    items.map(({ img, label }) => (
      <a
        class="audience-insights-thumb-link group relative block overflow-hidden rounded-md border border-black/10 shadow-sm outline-none ring-offset-2 transition-shadow hover:shadow-md focus-visible:ring-2 focus-visible:ring-black"
        href={img.src}
        data-pswp-width={img.width}
        data-pswp-height={img.height}
        aria-label={`${label} — open larger image`}
      >
        <Image
          class="h-full w-full object-cover transition-transform group-hover:scale-[1.02]"
          src={img}
          alt=""
          width={560}
          height={420}
          widths={[240, 400, 560]}
          sizes="(min-width: 640px) 25vw, 50vw"
          loading="lazy"
          decoding="async"
        />
      </a>
    ))
  }
</div>

<style>
  .audience-insights-thumb-link {
    aspect-ratio: 4 / 3;
  }
</style>
