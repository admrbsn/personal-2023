---
/**
 * Inline diagram (replaces tribute-v3-vibe-coding.png). Content from vibe-coding-diagram.html.
 */
---

<style is:global>
  @font-face {
    font-family: 'Martian Grotesk';
    src: url('/fonts/MartianGrotesk-VF.woff2') format('woff2');
    font-weight: 100 1000;
    font-stretch: 75% 200%;
    font-display: swap;
  }
</style>

<div class="vcd-root not-prose my-6" aria-label="Diagram comparing old design workflow vs constrained prompt workflow and sprint evolution">
  <div class="vcd-container">
    <div class="vcd-comparison-wrapper">
      <div class="vcd-comparison">
        <div class="vcd-comparison-col vcd-old">
          <div class="vcd-col-header">The old way</div>
          <div class="vcd-steps">
            <div class="vcd-step">
              <div class="vcd-step-number">1</div>
              <div class="vcd-step-title">Figma as source of truth</div>
              <div class="vcd-step-sub">Static specs only</div>
            </div>
            <div class="vcd-step">
              <div class="vcd-step-number">2</div>
              <div class="vcd-step-title">Handoff to engineers</div>
              <div class="vcd-step-sub">Specs lose fidelity</div>
            </div>
            <div class="vcd-step">
              <div class="vcd-step-number">3</div>
              <div class="vcd-step-title">React to mockups</div>
              <div class="vcd-step-sub">Weeks to decide</div>
            </div>
            <div class="vcd-step">
              <div class="vcd-step-number">4</div>
              <div class="vcd-step-title">Weeks of revision</div>
              <div class="vcd-step-sub">Momentum lost</div>
            </div>
          </div>
        </div>

        <div class="vcd-center-col">
          <div class="vcd-center-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14m-4-4l4 4-4 4"></path>
            </svg>
          </div>
        </div>

        <div class="vcd-comparison-col vcd-new">
          <div class="vcd-col-header">The new way</div>
          <div class="vcd-steps">
            <div class="vcd-step">
              <div class="vcd-step-number">1</div>
              <div class="vcd-step-title">Constrained prompt</div>
              <div class="vcd-step-sub">No vague asks</div>
            </div>
            <div class="vcd-step">
              <div class="vcd-step-number">2</div>
              <div class="vcd-step-title">Production components only</div>
              <div class="vcd-step-sub">No static specs</div>
            </div>
            <div class="vcd-step">
              <div class="vcd-step-number">3</div>
              <div class="vcd-step-title">One-week sprint cycles</div>
              <div class="vcd-step-sub">Lean UX + Agile</div>
            </div>
            <div class="vcd-step">
              <div class="vcd-step-number">4</div>
              <div class="vcd-step-title">Working code delivered</div>
              <div class="vcd-step-sub">Decisions in days, not weeks</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="vcd-evolution-section">
      <div class="vcd-evolution-header">
        <span class="vcd-evolution-label">How constraints tightened each sprint</span>
        <span class="vcd-evolution-line"></span>
      </div>
      <div class="vcd-evolution-grid">
        <div class="vcd-evolution-card">
          <div class="vcd-card-top">
            <div class="vcd-sprint-badge">Sprint 1</div>
            <p class="vcd-prompt-text">"Build a tribute creation page with cover image, title, and invite flow."</p>
          </div>
          <div class="vcd-card-bottom">
            <div class="vcd-constraint-label">Constraint level</div>
            <div class="vcd-constraint-bar"><div class="vcd-constraint-fill"></div></div>
          </div>
        </div>
        <div class="vcd-evolution-card">
          <div class="vcd-card-top">
            <div class="vcd-sprint-badge">Sprint 2</div>
            <p class="vcd-prompt-text">"Refactor using existing components. Match design tokens. No regressions."</p>
          </div>
          <div class="vcd-card-bottom">
            <div class="vcd-constraint-label">Constraint level</div>
            <div class="vcd-constraint-bar"><div class="vcd-constraint-fill"></div></div>
          </div>
        </div>
        <div class="vcd-evolution-card">
          <div class="vcd-card-top">
            <div class="vcd-sprint-badge">Sprint 3</div>
            <p class="vcd-prompt-text">"Polish end-to-end. Validate against production only. Stakeholder demo Friday."</p>
          </div>
          <div class="vcd-card-bottom">
            <div class="vcd-constraint-label">Constraint level</div>
            <div class="vcd-constraint-bar"><div class="vcd-constraint-fill"></div></div>
          </div>
        </div>
        <div class="vcd-evolution-card">
          <div class="vcd-card-top">
            <div class="vcd-sprint-badge">Sprint 4+</div>
            <p class="vcd-prompt-text">"No static specs. Stakeholder demo Friday. Working code only -- not a Figma file."</p>
          </div>
          <div class="vcd-card-bottom">
            <div class="vcd-constraint-label">Constraint level</div>
            <div class="vcd-constraint-bar"><div class="vcd-constraint-fill"></div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .vcd-root :global(*) {
    box-sizing: border-box;
  }

  .vcd-root {
    font-family: 'Martian Grotesk', ui-sans-serif, system-ui, sans-serif;
    background: linear-gradient(165deg, #faf8ff 0%, #f3effb 48%, #f5f3ff 100%);
    color: #404040;
    padding: 1.125rem 0.875rem;
    border-radius: 0.5rem;
    box-shadow:
      0 1px 3px rgb(76 29 149 / 0.07),
      0 0 0 1px rgb(139 92 246 / 0.06);
    border: 1px solid rgb(139 92 246 / 0.12);
    -webkit-font-smoothing: antialiased;
  }

  @media (min-width: 640px) {
    .vcd-root {
      padding: 1.25rem 1.125rem;
    }
  }

  .vcd-container {
    max-width: 52rem;
    margin: 0 auto;
  }

  .vcd-comparison-wrapper {
    margin-bottom: 1.375rem;
  }

  .vcd-comparison {
    display: grid;
    grid-template-columns: 1fr 40px 1fr;
    gap: 0;
  }

  @media (min-width: 640px) {
    .vcd-comparison {
      grid-template-columns: 1fr 52px 1fr;
    }
  }

  .vcd-comparison-col {
    text-align: center;
  }

  .vcd-col-header {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid;
  }

  @media (min-width: 640px) {
    .vcd-col-header {
      font-size: 11.5px;
    }
  }

  .vcd-old .vcd-col-header {
    color: #a8a29e;
    border-color: #d6d3d1;
  }
  .vcd-new .vcd-col-header {
    color: #5b21b6;
    border-color: rgb(124 58 237 / 0.45);
  }

  .vcd-steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .vcd-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3px 0;
    position: relative;
  }

  .vcd-step-number {
    width: 26px;
    height: 26px;
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 600;
    font-variation-settings: 'wdth' 90;
    margin-bottom: 3px;
  }

  .vcd-step-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 2px;
    letter-spacing: -0.01em;
  }

  @media (min-width: 640px) {
    .vcd-step-title {
      font-size: 15.5px;
    }
  }

  .vcd-step-sub {
    font-size: 12px;
    line-height: 1.4;
    font-weight: 400;
  }

  @media (min-width: 640px) {
    .vcd-step-sub {
      font-size: 13px;
    }
  }

  .vcd-step:not(:last-child)::after {
    content: '';
    display: block;
    width: 1px;
    height: 6px;
    margin-top: 4px;
  }

  .vcd-old .vcd-step-number {
    background: #e7e5e4;
    color: #a8a29e;
    border: 1px solid #d6d3d1;
  }
  .vcd-old .vcd-step:not(:last-child)::after {
    border-left: 1px dashed #d6d3d1;
  }
  .vcd-old .vcd-step-title {
    color: #a8a29e;
    text-decoration: line-through;
    text-decoration-color: #d6d3d1;
  }
  .vcd-old .vcd-step-sub {
    color: #c4c2c0;
  }

  .vcd-new .vcd-step-number {
    background: linear-gradient(145deg, #8b5cf6 0%, #6d28d9 50%, #5b21b6 100%);
    color: #fff;
    border: 1px solid rgb(167 139 250 / 0.5);
    box-shadow: 0 0 0 1px rgb(196 181 253 / 0.35);
  }
  .vcd-new .vcd-step:not(:last-child)::after {
    background: linear-gradient(180deg, #c4b5fd, #a78bfa);
  }
  .vcd-new .vcd-step-title {
    color: #312e81;
  }
  .vcd-new .vcd-step-sub {
    color: #5b5f8a;
  }

  .vcd-center-col {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vcd-center-arrow svg {
    width: 26px;
    height: 26px;
    color: #c4b5fd;
  }

  @media (min-width: 640px) {
    .vcd-center-arrow svg {
      width: 30px;
      height: 30px;
    }
  }

  .vcd-evolution-section {
    position: relative;
  }

  .vcd-evolution-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.875rem;
  }
  .vcd-evolution-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4c1d95;
  }

  @media (min-width: 640px) {
    .vcd-evolution-label {
      font-size: 11.5px;
    }
  }

  .vcd-evolution-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgb(196 181 253 / 0.35), rgb(139 92 246 / 0.2));
  }

  .vcd-evolution-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  @media (min-width: 768px) {
    .vcd-evolution-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .vcd-evolution-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .vcd-evolution-card {
    background: #fff;
    border-radius: 8px;
    padding: 14px 12px 11px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 132px;
    position: relative;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgb(76 29 149 / 0.06),
      0 8px 24px rgb(49 46 129 / 0.06);
    border: 1px solid rgb(139 92 246 / 0.12);
  }

  .vcd-evolution-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
  }
  .vcd-evolution-card:nth-child(1)::before {
    background: linear-gradient(90deg, #a78bfa, #8b5cf6);
  }
  .vcd-evolution-card:nth-child(2)::before {
    background: linear-gradient(90deg, #e879f9, #c026d3);
  }
  .vcd-evolution-card:nth-child(3)::before {
    background: linear-gradient(90deg, #818cf8, #4f46e5);
  }
  .vcd-evolution-card:nth-child(4)::before {
    background: linear-gradient(90deg, #c084fc, #7c3aed, #4c1d95);
  }

  .vcd-card-top {
    flex: 1;
  }

  .vcd-sprint-badge {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .vcd-evolution-card:nth-child(1) .vcd-sprint-badge {
    color: #6d28d9;
  }
  .vcd-evolution-card:nth-child(2) .vcd-sprint-badge {
    color: #a21caf;
  }
  .vcd-evolution-card:nth-child(3) .vcd-sprint-badge {
    color: #4338ca;
  }
  .vcd-evolution-card:nth-child(4) .vcd-sprint-badge {
    color: #e9d5ff;
  }

  .vcd-prompt-text {
    font-size: 15px;
    line-height: 1.55;
    color: #404040;
    margin: 0;
  }

  /* Final sprint: theme-drawer–style dark panel */
  .vcd-evolution-card:nth-child(4) {
    background: linear-gradient(165deg, #1a1528 0%, #0f0a18 100%);
    border-color: rgb(168 85 247 / 0.35);
    box-shadow:
      0 0 0 1px rgb(139 92 246 / 0.12),
      0 12px 32px rgb(0 0 0 / 0.35);
  }
  .vcd-evolution-card:nth-child(4) .vcd-prompt-text {
    color: #e9e4f5;
  }
  .vcd-evolution-card:nth-child(4) .vcd-constraint-label {
    color: #c4b5fd;
  }
  .vcd-evolution-card:nth-child(4) .vcd-constraint-bar {
    background: rgb(46 36 74 / 0.9);
  }

  .vcd-card-bottom {
    margin-top: 10px;
  }

  .vcd-constraint-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a8a29e;
    margin-bottom: 4px;
  }

  .vcd-constraint-bar {
    height: 4px;
    border-radius: 2px;
    background: #e7e5e4;
    overflow: hidden;
  }
  .vcd-constraint-fill {
    height: 100%;
    border-radius: 2px;
  }

  .vcd-evolution-card:nth-child(1) .vcd-constraint-fill {
    width: 25%;
    background: linear-gradient(90deg, #a78bfa, #8b5cf6);
    box-shadow: 0 0 12px rgb(167 139 250 / 0.45);
  }
  .vcd-evolution-card:nth-child(2) .vcd-constraint-fill {
    width: 50%;
    background: linear-gradient(90deg, #e879f9, #c026d3);
    box-shadow: 0 0 12px rgb(232 121 249 / 0.4);
  }
  .vcd-evolution-card:nth-child(3) .vcd-constraint-fill {
    width: 75%;
    background: linear-gradient(90deg, #818cf8, #4f46e5);
    box-shadow: 0 0 12px rgb(129 140 248 / 0.4);
  }
  .vcd-evolution-card:nth-child(4) .vcd-constraint-fill {
    width: 100%;
    background: linear-gradient(90deg, #f0abfc, #c084fc, #a855f7);
    box-shadow: 0 0 16px rgb(192 132 252 / 0.55);
  }
</style>
