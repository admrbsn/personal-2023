---
import { Image } from 'astro:assets'

interface Props {
  before: ImageMetadata
  after: ImageMetadata
  beforeLabel?: string
  afterLabel?: string
}

const { before, after, beforeLabel = 'Before', afterLabel = 'After' } = Astro.props
---

<div class="before-after-slider my-8" data-before-after-slider>
  <div class="before-after-slider__container">
    <!-- Before image (background, full width) -->
    <div class="before-after-slider__before">
      <Image
        src={before}
        alt={beforeLabel}
        class="before-after-slider__img"
        loading="eager"
        decoding="async"
      />
      <span class="before-after-slider__label before-after-slider__label--before" aria-hidden="true">{beforeLabel}</span>
    </div>
    <!-- After image (clipped overlay) -->
    <div class="before-after-slider__after" data-after>
      <Image
        src={after}
        alt={afterLabel}
        class="before-after-slider__img"
        loading="eager"
        decoding="async"
      />
      <span class="before-after-slider__label before-after-slider__label--after" aria-hidden="true">{afterLabel}</span>
    </div>
    <!-- Slider handle -->
    <div class="before-after-slider__handle" data-handle role="slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" tabindex="0">
      <div class="before-after-slider__handle-line"></div>
      <div class="before-after-slider__handle-grip">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M9 7L4 12L9 17M15 7L20 12L15 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<script>
  function initBeforeAfterSlider(root: HTMLElement) {
    const container = root.querySelector('.before-after-slider__container') as HTMLElement | null
    if (!container) return
    const afterEl = container.querySelector('[data-after]') as HTMLElement | null
    const handleEl = container.querySelector('[data-handle]') as HTMLElement | null
    if (!afterEl || !handleEl) return

    let isDragging = false
    let capturedPointerId: number | null = null

    const updatePosition = (clientX: number) => {
      const rect = container.getBoundingClientRect()
      if (!rect.width) return
      const x = Math.max(0, Math.min(clientX - rect.left, rect.width))
      const percent = (x / rect.width) * 100
      afterEl.style.clipPath = `inset(0 0 0 ${percent}%)`
      handleEl.style.left = `${percent}%`
      handleEl.setAttribute('aria-valuenow', Math.round(percent).toString())
    }

    const onPointerDown = (e: PointerEvent) => {
      e.preventDefault()
      isDragging = true
      capturedPointerId = e.pointerId
      handleEl.setPointerCapture(e.pointerId)
      updatePosition(e.clientX)
    }

    const onPointerMove = (e: PointerEvent) => {
      if (!isDragging) return
      updatePosition(e.clientX)
    }

    const onPointerUp = (e: PointerEvent) => {
      if (!isDragging || capturedPointerId == null || e.pointerId !== capturedPointerId) return
      isDragging = false
      try {
        handleEl.releasePointerCapture(capturedPointerId)
      } catch {
        /* already released */
      }
      capturedPointerId = null
    }

    handleEl.addEventListener('pointerdown', onPointerDown)
    window.addEventListener('pointermove', onPointerMove)
    window.addEventListener('pointerup', onPointerUp)
    window.addEventListener('pointercancel', onPointerUp)

    // Keyboard support
    handleEl.addEventListener('keydown', (e: KeyboardEvent) => {
      const rect = container.getBoundingClientRect()
      if (!rect.width) return
      const handleRect = handleEl.getBoundingClientRect()
      const currentX = handleRect.left - rect.left + handleRect.width / 2
      const step = rect.width / 50
      let newX = currentX
      if (e.key === 'ArrowLeft') newX = currentX - step
      else if (e.key === 'ArrowRight') newX = currentX + step
      if (newX !== currentX) {
        e.preventDefault()
        updatePosition(rect.left + newX)
      }
    })

    // Initial position 50% once layout (and images) have real dimensions
    const setInitial = () => {
      const rect = container.getBoundingClientRect()
      if (rect.width > 0) {
        updatePosition(rect.left + rect.width / 2)
      } else {
        requestAnimationFrame(setInitial)
      }
    }
    requestAnimationFrame(setInitial)

    const ro = new ResizeObserver(() => {
      const rect = container.getBoundingClientRect()
      if (rect.width > 0) {
        const pct = parseFloat(handleEl.getAttribute('aria-valuenow') || '50')
        const x = rect.left + (rect.width * Math.min(100, Math.max(0, pct))) / 100
        updatePosition(x)
      }
    })
    ro.observe(container)

    // Re-sync after images decode (avoid transparent “after” layer showing “before” through)
    const imgs = container.querySelectorAll<HTMLImageElement>('.before-after-slider__img')
    imgs.forEach((img) => {
      if (img.complete) return
      img.addEventListener('load', () => setInitial(), { once: true })
    })
  }

  document.querySelectorAll('[data-before-after-slider]').forEach((el) => initBeforeAfterSlider(el as HTMLElement))
</script>

<style>
  .before-after-slider {
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }

  .before-after-slider__container {
    position: relative;
    aspect-ratio: 4 / 3;
    min-height: 200px;
  }

  .before-after-slider__before,
  .before-after-slider__after {
    position: absolute;
    inset: 0;
  }

  .before-after-slider__before {
    z-index: 0;
  }

  .before-after-slider__after {
    z-index: 1;
    clip-path: inset(0 0 0 50%);
    pointer-events: none;
  }

  .before-after-slider__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .before-after-slider__label {
    position: absolute;
    bottom: 0.75rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: rgba(0, 0, 0, 0.6);
    color: white;
    border-radius: 0.25rem;
  }

  .before-after-slider__label--before {
    left: 0.75rem;
  }

  .before-after-slider__label--after {
    right: 0.75rem;
    left: auto;
  }

  .before-after-slider__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 4px;
    transform: translateX(-50%);
    z-index: 2;
    cursor: ew-resize;
    display: flex;
    align-items: center;
    justify-content: center;
    touch-action: none;
    overflow: visible;
  }

  .before-after-slider__handle-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background: white;
    transform: translateX(-50%);
    box-shadow: 0 0 4px rgba(0, 0, 0, 0.5);
  }

  .before-after-slider__handle-grip {
    position: relative;
    width: 36px;
    height: 36px;
    min-width: 36px;
    min-height: 36px;
    aspect-ratio: 1;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    color: #374151;
  }

  .before-after-slider__handle:focus {
    outline: none;
  }

  .before-after-slider__handle:focus-visible .before-after-slider__handle-grip {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }
</style>
