---
export interface Props {
	dates: string;
	role: string;
	body: string;
}

const { dates, role, body } = Astro.props;
---

<li class="mb-8 pb-8 border-b experience-item">
	<div class="experience-dates text-lg font-semibold">{dates}</div>
	<div class="mb-5 text-2xl font-extrabold">{role}</div>
	<div set:html={body}></div>
</li>

<style>
	.experience-dates {
		color: #6b5b4a;
	}
	.experience-item {
		border-color: rgba(107, 91, 74, 0.25);
	}
	li:last-child {
		@apply mb-0 pb-0 border-0;
	}
</style>